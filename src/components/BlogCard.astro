---
import type { BlogPost } from "../utils/posts";
import { excerpt, formatDate, postUrl, readTime } from "../utils/posts";
import { withBase } from "../config";

interface Props {
  post: BlogPost;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const image = post.data.image.startsWith("/") ? withBase(post.data.image) : post.data.image;
const href = withBase(postUrl(post));
---

<a
  class="blog-card"
  href={href}
  data-search={`${post.data.title} ${post.data.description} ${post.data.tags.join(" ")}`.toLowerCase()}
  data-reveal
  style={`--reveal-delay: ${Math.min(index * 60, 360)}ms;`}
>
  <div class="blog-card__thumb" style={`background-image: url("${image}");`}></div>
  <div class="blog-card__body">
    <p class="blog-card__meta">
      <span>{formatDate(post.data.pubDate)}</span>
      <span>•</span>
      <span>{readTime(post.body)} min read</span>
    </p>
    <h2 class="blog-card__title">{post.data.title}</h2>
    <p class="blog-card__excerpt">{excerpt(post.body)}</p>
    <span class="blog-card__cta">Continue reading →</span>
  </div>
</a>
