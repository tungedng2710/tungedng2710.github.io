---
import { site, withBase } from "../config";

const authorImage = site.author.image.startsWith("/")
  ? withBase(site.author.image)
  : site.author.image;
---

<section class="hero is-fullheight has-text-centered" id="about">
  <div class="hero-body">
    <div class="container">
      <div class="about-heading" data-reveal>
        <p class="section-kicker">About</p>
        <h2>Research-minded. Product-focused.</h2>
      </div>
      <div class="columns is-vcentered about-grid">
        <div class="column is-one-third-desktop is-one-third-tablet" data-reveal>
          <div class="profile-frame">
            <figure class="image">
              <img src={authorImage} alt={site.author.name} />
            </figure>
          </div>
          <div class="profile-caption">
            <span class="status-dot"></span>
            Based in Vietnam · Working globally
          </div>
        </div>
        <div
          class="column has-text-left-desktop has-text-left-tablet has-text-left-fullhd"
          data-reveal
          style="--reveal-delay: 100ms;"
        >
          <div class="about-card">
            <p class="about-label">Tung Nguyen · AI researcher & engineer</p>
            <p>{site.author.about}</p>
            <div class="container columns is-centered">
              <div>
                <a
                  href={`mailto:${site.email}`}
                  class="button is-rounded is-uppercase has-text-weight-normal"
                >
                  Email
                </a>
              </div>
              <div>
                <a
                  href={withBase("/project")}
                  class="button is-rounded is-uppercase has-text-weight-normal"
                >
                  Projects
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="columns is-centered contact-strip" data-reveal>
        <div class="column is-three-quarters">
          <p class="contact-kicker">Have an interesting problem?</p>
          <h3>Let’s build something thoughtful.</h3>
          <div class="is-size-2 social-links">
            <a href={`mailto:${site.email}`} aria-label="Email">
              <i class="fas fa-envelope"></i>
            </a>
            <a href={site.social.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
              <i class="fab fa-linkedin"></i>
            </a>
            <a href={site.social.github} target="_blank" rel="noreferrer" aria-label="GitHub">
              <i class="fab fa-github"></i>
            </a>
            <a href={site.social.youtube} target="_blank" rel="noreferrer" aria-label="YouTube">
              <i class="fab fa-youtube"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .profile-frame {
    position: relative;
    max-width: 340px;
    margin: 0 auto;
    padding: 8px;
    border-radius: 30px;
    background: linear-gradient(145deg, #dbeafe, #ede9fe 50%, #cffafe);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.14);
  }

  .profile-frame .image {
    margin: 0;
  }

  .profile-frame img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    border: 0 !important;
    border-radius: 23px;
  }

  .about-card {
    padding: clamp(1.75rem, 4vw, 3rem);
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
  }

  .about-card > p {
    color: #475569 !important;
    font-size: 1.04rem;
    line-height: 1.85;
    text-align: left;
  }

  .about-card .about-label {
    margin-bottom: 1rem;
    color: #2563eb !important;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .profile-caption {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 1rem;
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 5px rgba(34, 197, 94, 0.12);
  }

  .contact-strip {
    margin-top: clamp(4rem, 8vw, 7rem) !important;
    padding: clamp(2rem, 5vw, 3.5rem);
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 30px;
    background: linear-gradient(135deg, rgba(239, 246, 255, 0.9), rgba(250, 245, 255, 0.9));
  }

  .contact-kicker {
    margin-bottom: 0.6rem;
    color: #2563eb !important;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h3 {
    margin-bottom: 1.4rem;
    color: #0f172a;
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    font-weight: 750;
    letter-spacing: -0.04em;
  }

  .social-links {
    margin-top: 1rem;
  }

  .social-links a {
    display: inline-grid;
    width: 46px;
    height: 46px;
    min-width: 0 !important;
    margin: 0 0.3rem !important;
    place-items: center;
    border: 1px solid rgba(148, 163, 184, 0.3);
    border-radius: 14px;
    background: white;
    color: #334155;
    font-size: 1.15rem;
    transition: transform 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }

  .social-links a:hover {
    color: #2563eb;
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(37, 99, 235, 0.14);
  }
</style>
