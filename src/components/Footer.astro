---
import { site, withBase } from "../config";
---

<footer id="footer">
  <div class="footer-inner">
    <a class="footer-brand" href={withBase("/")}>
      <img src={withBase("/assets/images/logo.png")} alt="" />
      <span>
        <strong>{site.title}</strong>
        <small>AI research & engineering</small>
      </span>
    </a>
    <nav aria-label="Footer navigation">
      <a href={withBase("/blog")}>Writing</a>
      <a href={withBase("/project")}>Projects</a>
      <a href={site.social.github} target="_blank" rel="noreferrer">GitHub</a>
      <a href={site.social.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
    </nav>
    <p>© {new Date().getFullYear()} {site.author.name}</p>
  </div>
</footer>
