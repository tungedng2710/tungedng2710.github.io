---
import { site, withBase } from "../config";

interface Props {
  active?: "home" | "blog" | "project";
}

const { active } = Astro.props;
---

<nav class="navbar is-fixed-top" role="navigation" aria-label="main navigation" id="navbar">
  <div class="container">
    <div class="navbar-brand">
      <a class="navbar-item" href={withBase("/")}>
        <img
          src={withBase("/assets/images/logo.png")}
          alt={`${site.title} logo`}
          style="max-height: 40px; margin-right: 10px;"
        />
        <strong>{site.title}</strong>
      </a>
      <button
        class="navbar-burger"
        type="button"
        aria-label="menu"
        aria-expanded="false"
        aria-controls="navbar-menu"
        data-target="navbar-menu"
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>

    <div class="navbar-menu" id="navbar-menu">
      <div class="navbar-end">
        <a class:list={["navbar-item", { "is-active": active === "home" }]} href={withBase("/")}>
          HOME
        </a>
        <a class="navbar-item" href={withBase("/#about")}>ABOUT</a>
        <a class:list={["navbar-item", { "is-active": active === "blog" }]} href={withBase("/blog")}>
          BLOG
        </a>
        <a
          class:list={["navbar-item", { "is-active": active === "project" }]}
          href={withBase("/project")}
        >
          PROJECTS
        </a>
        <a class="navbar-contact" href={`mailto:${site.email}`}>LET’S TALK</a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.querySelectorAll<HTMLButtonElement>(".navbar-burger").forEach((burger) => {
    burger.addEventListener("click", () => {
      const targetId = burger.dataset.target;
      const target = targetId ? document.getElementById(targetId) : null;
      const isOpen = burger.classList.toggle("is-active");
      target?.classList.toggle("is-active", isOpen);
      burger.setAttribute("aria-expanded", String(isOpen));
    });
  });
</script>
